---
import '@styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  /** Ürün sayfalarında true — model-viewer scripti sadece bu durumda yüklenir */
  loadModelViewer?: boolean;
  /** body class override */
  bodyClass?: string;
  /** Debug sayfaları için: robot index'leme */
  noindex?: boolean;
}

const {
  title = 'Atelier Anatolia · 3D Mobilya Kataloğu',
  description = 'Anadolu zanaatını modern minimalizmle buluşturan mobilya kataloğu. Her parça 3D olarak incelenebilir.',
  ogImage,
  loadModelViewer = false,
  bodyClass = '',
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#fbf9f7" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />

    {/* OpenGraph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    {/* Fonts — preconnect + load DM Sans + EB Garamond + Material Symbols */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=EB+Garamond:ital,wght@0,400..700;1,400..600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,200..700,0..1,-50..200&display=swap"
      rel="stylesheet"
    />

    {/* model-viewer — yalnızca ürün sayfalarında, defer */}
    {loadModelViewer && (
      <script
        is:inline
        type="module"
        src="https://unpkg.com/@google/model-viewer@3.5.0/dist/model-viewer.min.js"
        defer
      />
    )}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Sayfa-spesifik head içerik (JSON-LD, vb.) */}
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    {/* Klavye kullanıcıları için */}
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[60] focus:bg-primary focus:text-on-primary focus:px-4 focus:py-3 focus:rounded-full focus:text-[12px] focus:uppercase focus:tracking-widest focus:font-bold"
    >
      İçeriğe atla
    </a>

    <slot />

    {/* QR ribbon — ?ref=qr varsa render edilir, brand-guide "QR-Arrival Ribbon" */}
    <script is:inline>
      (() => {
        const params = new URLSearchParams(location.search);
        if (params.get('ref') !== 'qr') return;
        if (sessionStorage.getItem('qr-ribbon-seen')) return;
        const customer = document.documentElement.dataset.customer ?? 'Atelier Anatolia';
        const ribbon = document.createElement('div');
        ribbon.className =
          'fixed top-0 inset-x-0 z-50 bg-tertiary-c text-on-tertiary-c text-[11px] tracking-[0.2em] uppercase font-bold text-center py-2.5';
        ribbon.textContent = `Mağazadan geldiniz · ${customer}`;
        document.body.prepend(ribbon);
        sessionStorage.setItem('qr-ribbon-seen', '1');
      })();
    </script>
  </body>
</html>
