---
/**
 * Ürün detay sayfası — tek route, responsive layout.
 * Mock: tasarimlar/urun-detay-desktop/code.html + urun-detay-mobile/code.html
 *
 * Desktop: 7-5 split (sticky viewer solda, içerik sağda)
 * Mobile: tek kolon + sticky bottom action bar
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import ProductViewer from '@components/ProductViewer.astro';
import ProductCard from '@components/ProductCard.astro';
import FabricSwatchGroup from '@components/FabricSwatchGroup.astro';
import DimensionSketch from '@components/DimensionSketch.astro';
import CollapsibleSpec from '@components/CollapsibleSpec.astro';
import ArtisanQuote from '@components/ArtisanQuote.astro';
import HorizontalScroller from '@components/HorizontalScroller.astro';
import StickyActionBar from '@components/StickyActionBar.astro';
import EyebrowLabel from '@components/EyebrowLabel.astro';
import DisplayHeading from '@components/DisplayHeading.astro';
import {
  getProductSlugs,
  getProduct,
  getSimilarProducts,
  getCustomer,
  getCategory,
  buildWhatsAppLink,
} from '@lib/data';

export async function getStaticPaths() {
  return getProductSlugs().map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params as { slug: string };
const product = getProduct(slug);
if (!product) {
  return Astro.redirect('/kategoriler');
}

const customer = getCustomer();
const category = getCategory(product.category);
const similar = getSimilarProducts(product, 4);
const initialFabric = product.fabrics[0];
const waLink = buildWhatsAppLink(customer.contact.whatsapp, product, initialFabric?.name);
const telLink = `tel:${customer.contact.phone}`;
const productFullName = product.italicWord ? `${product.name} ${product.italicWord}` : product.name;
const hasDims = product.dimensions.w > 0;

// JSON-LD
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: productFullName,
  description: product.description.body,
  image: [product.posterUrl, ...product.galleryImages],
  brand: { '@type': 'Brand', name: customer.brand.name },
  category: category?.name ?? product.category,
  offers: {
    '@type': 'Offer',
    priceCurrency: 'TRY',
    price: '0',
    availability: 'https://schema.org/InStock',
    seller: { '@type': 'Organization', name: customer.brand.name },
  },
};
---

<BaseLayout
  title={`${productFullName} · ${customer.brand.name}`}
  description={product.description.body.slice(0, 160)}
  ogImage={product.posterUrl}
  loadModelViewer={false}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <Header active={null} />

  <main id="main-content" class="pb-24 md:pb-16">
    {/* Breadcrumb */}
    <nav class="max-w-[1320px] mx-auto px-5 md:px-12 pt-6 text-[11px] uppercase tracking-widest text-on-surface-v">
      <a href="/" class="hover:text-primary transition">Ana sayfa</a>
      <span class="mx-2 opacity-50">/</span>
      <a href="/kategoriler" class="hover:text-primary transition">Koleksiyonlar</a>
      {category && (
        <>
          <span class="mx-2 opacity-50">/</span>
          <a href={`/kategori/${category.slug}`} class="hover:text-primary transition">{category.shortLabel}</a>
        </>
      )}
      <span class="mx-2 opacity-50">/</span>
      <span class="text-primary">{product.name}</span>
    </nav>

    {/* Main split */}
    <div class="max-w-[1320px] mx-auto px-5 md:px-12 mt-6 md:mt-10 grid grid-cols-1 lg:grid-cols-12 gap-8 md:gap-12">
      {/* Viewer column — sticky on desktop */}
      <div class="lg:col-span-7">
        <div class="lg:sticky lg:top-24">
          <ProductViewer product={product} />

          {/* Dimension sketch — under viewer */}
          {hasDims && (
            <div class="mt-6 md:mt-8">
              <DimensionSketch
                width={product.dimensions.w}
                depth={product.dimensions.d}
                height={product.dimensions.h}
              />
            </div>
          )}
        </div>
      </div>

      {/* Details column */}
      <div class="lg:col-span-5">
        <EyebrowLabel text={product.description.eyebrow} />
        <DisplayHeading
          as="h1"
          name={product.name}
          italicWord={product.italicWord}
          size="lg"
          class="mt-3"
        />

        {/* Quick meta */}
        <div class="mt-5 flex flex-wrap items-center gap-4 md:gap-6">
          {hasDims && (
            <div class="text-[14px]">
              <span class="text-on-surface-v">Ölçü: </span>
              <span class="font-bold">{product.dimensions.w} × {product.dimensions.d} × {product.dimensions.h} cm</span>
            </div>
          )}
          <div class="text-[14px]">
            <span class="text-on-surface-v">Teslimat: </span>
            <span class="font-bold">{product.deliveryTime}</span>
          </div>
        </div>

        {/* Pricing — italic, editorial */}
        <p class="font-display italic text-headline-md mt-5 text-primary">{product.priceNote}</p>

        {/* Description with dropcap */}
        <div class="mt-7 md:mt-8 text-[15px] md:text-[16px] leading-relaxed">
          <p>
            <span class="float-left font-display italic text-[3.6rem] md:text-[5.5rem] leading-[0.85] pr-2 md:pr-[0.55rem] pt-1 text-primary">
              {product.description.dropcap}
            </span>
            {product.description.body}
          </p>
        </div>

        {/* Features chips */}
        {product.features.length > 0 && (
          <div class="mt-7 md:mt-8">
            <EyebrowLabel text="Özellikler" />
            <div class="overflow-x-auto no-scrollbar -mx-5 md:mx-0 mt-3">
              <div class="flex gap-2 px-5 md:px-0 min-w-max md:flex-wrap md:min-w-0">
                {product.features.map((f) => (
                  <span class="shrink-0 bg-surface-c-low px-3 py-2 rounded-full text-[11px] md:text-[12px] tracking-wide">
                    {f}
                  </span>
                ))}
              </div>
            </div>
          </div>
        )}

        {/* Fabric swatches */}
        {product.fabrics.length > 0 && (
          <div class="mt-8 md:mt-10 bg-surface-c-low rounded-2xl p-5 md:p-7">
            <FabricSwatchGroup product={product} />
          </div>
        )}

        {/* CTA pair — desktop only (mobile has sticky bar) */}
        <div class="hidden md:flex flex-wrap gap-3 mt-8">
          <a
            href={waLink}
            data-wa-link
            class="flex-1 min-w-[200px] inline-flex items-center justify-center gap-2 bg-whatsapp text-white py-4 px-6 rounded-full text-[12px] uppercase tracking-[0.22em] font-bold hover:opacity-90 transition"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448L.057 24z"/>
            </svg>
            WhatsApp ile sor
          </a>
          <a
            href={telLink}
            class="inline-flex items-center justify-center gap-2 bg-surface-c text-primary py-4 px-6 rounded-full text-[12px] uppercase tracking-[0.22em] font-bold hover:bg-surface-c-high transition"
          >
            <span class="material-symbols-outlined text-[18px]">call</span>
            Telefon
          </a>
          <button
            data-share-button
            data-share-title={productFullName}
            class="w-14 h-14 rounded-full bg-surface-c text-primary grid place-items-center hover:bg-surface-c-high transition"
            aria-label="Paylaş"
          >
            <span class="material-symbols-outlined">share</span>
          </button>
        </div>

        {/* Specs accordion */}
        <div class="mt-8 md:mt-10 bg-surface rounded-2xl ambient p-5 md:p-7">
          <CollapsibleSpec title="Teknik özellikler" icon="straighten" items={product.specs.technical} defaultOpen />
          <CollapsibleSpec title="Bakım & garanti" icon="health_and_safety" items={product.specs.care} />
          <CollapsibleSpec title="Üretim & teslimat" icon="local_shipping" items={product.specs.shipping} />
        </div>

        {/* Artisan quote */}
        {product.artisan && (
          <div class="mt-8 md:mt-10">
            <ArtisanQuote quote={product.artisan} variant="card" />
          </div>
        )}
      </div>
    </div>

    {/* Similar products */}
    {similar.length > 0 && (
      <section class="mt-16 md:mt-24">
        <div class="max-w-[1320px] mx-auto px-5 md:px-12 mb-6 md:mb-8">
          <EyebrowLabel text="Benzer ürünler" hairline />
          <DisplayHeading as="h2" name="Belki de" italicWord="bunlar" size="md" class="mt-3" />
        </div>

        {/* Mobile: horizontal scroller. Desktop: grid */}
        <div class="md:hidden">
          <HorizontalScroller>
            {similar.map((p) => (
              <div class="min-w-[260px] snap-start">
                <ProductCard product={p} />
              </div>
            ))}
          </HorizontalScroller>
        </div>
        <div class="hidden md:block max-w-[1320px] mx-auto px-5 md:px-12">
          <div class="grid grid-cols-4 gap-6">
            {similar.map((p) => <ProductCard product={p} />)}
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer />
  <StickyActionBar product={product} />

  <script>
    import '@scripts/toast';
    import '@scripts/share';
    import '@scripts/fabric-swatch';
    import '@scripts/product-viewer';
  </script>
</BaseLayout>
