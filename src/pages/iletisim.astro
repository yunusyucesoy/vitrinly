---
/**
 * İletişim sayfası.
 * Mock: tasarimlar/iletisim/code.html
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import MapPin from '@components/MapPin.astro';
import EyebrowLabel from '@components/EyebrowLabel.astro';
import DisplayHeading from '@components/DisplayHeading.astro';
import WhatsAppFAB from '@components/WhatsAppFAB.astro';
import { getCustomer, buildWhatsAppLink } from '@lib/data';

const customer = getCustomer();
const waLink = buildWhatsAppLink(customer.contact.whatsapp);
const showroom = customer.locations.find((l) => l.type === 'showroom') ?? customer.locations[0];
const atolye = customer.locations.find((l) => l.type === 'atolye');
---

<BaseLayout
  title={`İletişim · ${customer.brand.name}`}
  description="WhatsApp, telefon, e-posta ve showroom adresi. Nişantaşı'nda bekliyoruz."
>
  <Header active="iletisim" />

  <main id="main-content" class="pb-16 md:pb-24">
    {/* Hero */}
    <section class="max-w-[1320px] mx-auto px-5 md:px-12 pt-10 md:pt-16 pb-10 md:pb-16 grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-10 items-end">
      <div class="md:col-span-7 reveal d1">
        <EyebrowLabel text="İletişim" />
        <DisplayHeading
          as="h1"
          name="Nasıl"
          italicWord="ulaşabilirsiniz"
          size="hero"
          class="mt-4"
        />
      </div>
      <div class="md:col-span-5 reveal d2">
        <p class="font-display italic text-[18px] md:text-[22px] text-on-surface-v leading-relaxed">
          WhatsApp en hızlı yolumuz — genellikle dakikalar içinde dönüyoruz. Tabii ki uğramak da serbest.
        </p>
      </div>
    </section>

    {/* Primary CTA cards (3) */}
    <section class="max-w-[1320px] mx-auto px-5 md:px-12 grid grid-cols-1 md:grid-cols-3 gap-3 md:gap-6">
      {/* WhatsApp */}
      <a
        href={waLink}
        class="group bg-whatsapp text-white rounded-3xl p-7 md:p-8 ambient flex flex-col justify-between gap-6 min-h-[200px] md:min-h-[240px] hover:opacity-95 transition"
      >
        <div>
          <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
            <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448L.057 24z"/>
          </svg>
          <h3 class="font-display text-[28px] md:text-[32px] mt-4 tracking-tight">WhatsApp</h3>
          <p class="text-[13px] opacity-80 mt-2 leading-relaxed">Bir ürün hakkında soru, ölçü onayı veya teklif için. En hızlı kanal.</p>
        </div>
        <div>
          <div class="font-display text-[18px] md:text-[22px] leading-none">{customer.contact.whatsappFormatted}</div>
          <span class="inline-flex items-center gap-2 mt-3 text-[11px] uppercase tracking-widest font-bold border-b border-white w-fit pb-1">
            Yazışmaya başla <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
          </span>
        </div>
      </a>

      {/* Phone */}
      <a
        href={`tel:${customer.contact.phone}`}
        class="group bg-primary text-on-primary rounded-3xl p-7 md:p-8 ambient flex flex-col justify-between gap-6 min-h-[200px] md:min-h-[240px] hover:opacity-95 transition"
      >
        <div>
          <span class="material-symbols-outlined text-[32px] icon-fill">call</span>
          <h3 class="font-display text-[28px] md:text-[32px] mt-4 tracking-tight">Telefon</h3>
          <p class="text-[13px] opacity-80 mt-2 leading-relaxed">Konuşmayı tercih ederseniz — çalışma saatlerinde hattımızı arayın.</p>
        </div>
        <div>
          <div class="font-display text-[18px] md:text-[22px] leading-none">{customer.contact.whatsappFormatted}</div>
          <span class="inline-flex items-center gap-2 mt-3 text-[11px] uppercase tracking-widest font-bold border-b border-on-primary w-fit pb-1">
            Ara <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
          </span>
        </div>
      </a>

      {/* Email */}
      <a
        href={`mailto:${customer.contact.email}`}
        class="group bg-secondary-c text-on-secondary-c rounded-3xl p-7 md:p-8 ambient flex flex-col justify-between gap-6 min-h-[200px] md:min-h-[240px] hover:opacity-95 transition"
      >
        <div>
          <span class="material-symbols-outlined text-[32px] icon-fill">mail</span>
          <h3 class="font-display text-[28px] md:text-[32px] mt-4 tracking-tight">E-posta</h3>
          <p class="text-[13px] opacity-80 mt-2 leading-relaxed">Detaylı proje açıklamaları, ekli görseller için en uygun yol.</p>
        </div>
        <div>
          <div class="font-display text-[16px] md:text-[18px] leading-none break-all">{customer.contact.email}</div>
          <span class="inline-flex items-center gap-2 mt-3 text-[11px] uppercase tracking-widest font-bold border-b border-on-secondary-c w-fit pb-1">
            E-posta yaz <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
          </span>
        </div>
      </a>
    </section>

    {/* Showroom + map + info cards */}
    <section id="showroom" class="max-w-[1320px] mx-auto px-5 md:px-12 mt-16 md:mt-24">
      <div class="mb-10 md:mb-12">
        <EyebrowLabel text="Showroom" hairline />
        <DisplayHeading as="h2" name="Nişantaşı" italicWord="atölyesi" size="lg" class="mt-3" />
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 md:gap-8">
        <div class="lg:col-span-7">
          <MapPin location={showroom} aspect="4-3" />
        </div>

        <div class="lg:col-span-5 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-4 md:gap-6">
          {/* Hours */}
          <div class="bg-surface rounded-2xl p-5 md:p-6 ambient hover:bg-surface-c-low transition">
            <span class="material-symbols-outlined text-tertiary">schedule</span>
            <h4 class="font-display text-[18px] md:text-[22px] mt-3">Çalışma saatleri</h4>
            <ul class="mt-3 space-y-1.5 text-[13px] md:text-[14px]">
              {showroom.hours.map((h) => (
                <li class="flex justify-between gap-4">
                  <span class="text-on-surface-v">{h.days}</span>
                  <span class="font-bold">{h.range}</span>
                </li>
              ))}
            </ul>
          </div>

          {/* Booking */}
          <div class="bg-surface rounded-2xl p-5 md:p-6 ambient hover:bg-surface-c-low transition">
            <span class="material-symbols-outlined text-tertiary">event_available</span>
            <h4 class="font-display text-[18px] md:text-[22px] mt-3">Randevu</h4>
            <p class="text-[13px] md:text-[14px] text-on-surface-v mt-2 leading-relaxed">
              Yoğun cumartesileri kaçırmamak için WhatsApp'tan randevu alabilirsiniz.
            </p>
            <a
              href={`https://wa.me/${customer.contact.whatsapp.replace(/[^\d]/g, '')}?text=${encodeURIComponent('Showroom randevusu almak istiyorum')}`}
              class="mt-4 inline-flex items-center gap-2 text-[11px] uppercase tracking-widest font-bold border-b border-primary pb-1 hover:opacity-70 transition"
            >
              Randevu al <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
            </a>
          </div>

          {/* QR tip */}
          <div class="sm:col-span-2 lg:col-span-1 bg-secondary-c text-on-secondary-c rounded-2xl p-5 md:p-6">
            <span class="material-symbols-outlined">qr_code_2</span>
            <h4 class="font-display text-[18px] md:text-[22px] mt-3">Mağazada QR</h4>
            <p class="text-[13px] md:text-[14px] opacity-80 mt-2 leading-relaxed">
              Her ürünün etiketinde bir QR kod var. Telefonla okutun, ürünü 3D'de evinizde görmek için ön hazırlık.
            </p>
          </div>
        </div>
      </div>

      <div class="mt-6 md:mt-8 text-[13px] md:text-[14px] text-on-surface-v">
        <span class="material-symbols-outlined text-[16px] mr-2">location_on</span>
        {showroom.directions}
      </div>
    </section>

    {/* Atölye section (varsa) */}
    {atolye && (
      <section class="max-w-[1320px] mx-auto px-5 md:px-12 mt-16 md:mt-24 bg-surface-c-low rounded-3xl p-8 md:p-12">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10 items-start">
          <div class="md:col-span-5">
            <EyebrowLabel text="Atölye" hairline />
            <DisplayHeading as="h2" name="Üretim" italicWord="merkezi" size="md" class="mt-3" />
            <p class="font-display italic text-[16px] md:text-[18px] text-on-surface-v mt-4 leading-relaxed">
              {atolye.directions}
            </p>
          </div>
          <div class="md:col-span-7">
            <div class="space-y-4">
              <div class="flex items-start gap-4 border-b border-outline-v/40 pb-4">
                <span class="material-symbols-outlined text-primary mt-1">location_on</span>
                <div>
                  <div class="text-[10.5px] tracking-widest uppercase text-on-surface-v font-bold">Adres</div>
                  <div class="font-display text-[16px] md:text-[18px]">{atolye.addressLines[0]}</div>
                  <div class="text-[13px] text-on-surface-v">{atolye.district} / {atolye.city}</div>
                </div>
              </div>
              <div class="flex items-start gap-4 border-b border-outline-v/40 pb-4">
                <span class="material-symbols-outlined text-primary mt-1">call</span>
                <div>
                  <div class="text-[10.5px] tracking-widest uppercase text-on-surface-v font-bold">Telefon</div>
                  <div class="font-display text-[16px] md:text-[18px]">{atolye.phone}</div>
                </div>
              </div>
              {atolye.mapLink && (
                <a
                  href={atolye.mapLink}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-2 text-[11px] uppercase tracking-widest font-bold border-b border-primary pb-1 hover:opacity-70 transition"
                >
                  Yol tarifi <span class="material-symbols-outlined text-[14px]">north_east</span>
                </a>
              )}
            </div>
          </div>
        </div>
      </section>
    )}

    {/* Social */}
    <section class="max-w-[1320px] mx-auto px-5 md:px-12 mt-16 md:mt-24 text-center">
      <EyebrowLabel text="Bizi takip edin" />
      <div class="mt-6 flex justify-center flex-wrap gap-3">
        {customer.social.map((s) => (
          <a
            href={s.url}
            class="group flex items-center gap-3 bg-surface px-5 py-3 rounded-full ambient hover:bg-surface-c-low transition"
            aria-label={s.platform}
          >
            <span class="material-symbols-outlined text-primary">{s.icon}</span>
            <span class="text-[12px] uppercase tracking-widest font-bold">{s.handle ?? s.platform}</span>
          </a>
        ))}
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppFAB />
</BaseLayout>
