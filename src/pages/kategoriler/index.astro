---
/**
 * Tüm kategoriler grid sayfası.
 * Mock: tasarimlar/kategoriler/code.html
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import CategoryCard from '@components/CategoryCard.astro';
import EyebrowLabel from '@components/EyebrowLabel.astro';
import DisplayHeading from '@components/DisplayHeading.astro';
import ArtisanQuote from '@components/ArtisanQuote.astro';
import WhatsAppFAB from '@components/WhatsAppFAB.astro';
import { getCustomer, getCategories, getProducts } from '@lib/data';

const customer = getCustomer();
const categories = getCategories();
const products = getProducts();
const counts = Object.fromEntries(categories.map((c) => [c.slug, products.filter((p) => p.category === c.slug).length]));
const totalProducts = products.length;

const headerCategory = categories[0];           // featured large
const subCategories = categories.slice(1, 5);    // 4 normal
const customCategory = categories.find((c) => c.isCustomOrder);
const inlineQuote = headerCategory.artisanQuote;
---

<BaseLayout
  title={`Koleksiyonlar · ${customer.brand.name}`}
  description={`${totalProducts} ürün · 6 koleksiyon. Oturma, yatak, yemek odası ve daha fazlası — 3D'de incelenebilir.`}
>
  <Header active="kategoriler" />

  <main id="main-content">
    {/* Breadcrumb */}
    <nav class="max-w-[1320px] mx-auto px-5 md:px-12 pt-6 text-[11px] uppercase tracking-widest text-on-surface-v">
      <a href="/" class="hover:text-primary transition">Ana sayfa</a>
      <span class="mx-2 opacity-50">/</span>
      <span class="text-primary">Koleksiyonlar</span>
    </nav>

    {/* Editorial header */}
    <header class="max-w-[1320px] mx-auto px-5 md:px-12 pt-8 md:pt-12 pb-10 md:pb-16 grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10 items-end">
      <div class="md:col-span-7">
        <EyebrowLabel text="Tüm koleksiyon" />
        <DisplayHeading as="h1" name="Odadan" italicWord="odaya" size="hero" class="mt-4" />
      </div>
      <div class="md:col-span-5">
        <p class="font-display italic text-[16px] md:text-[20px] text-on-surface-v leading-relaxed">
          Her oda için titizlikle hazırlanmış {categories.length} koleksiyon, toplam {totalProducts} eser. Hepsi 3D olarak incelenebilir.
        </p>
      </div>
    </header>

    {/* Filter chips */}
    <div class="max-w-[1320px] mx-auto px-5 md:px-12 mb-10 md:mb-12">
      <div class="overflow-x-auto no-scrollbar -mx-5 md:mx-0">
        <div class="flex gap-2 md:gap-3 px-5 md:px-0">
          <button class="shrink-0 bg-primary text-on-primary px-4 py-2.5 rounded-full text-[11px] uppercase tracking-widest font-bold">
            Tümü · {totalProducts}
          </button>
          {categories.map((c) => (
            <a
              href={`/kategori/${c.slug}`}
              class="shrink-0 bg-surface-c-low hover:bg-surface-c text-on-surface px-4 py-2.5 rounded-full text-[11px] uppercase tracking-widest font-bold transition"
            >
              {c.shortLabel} · {counts[c.slug]}
            </a>
          ))}
        </div>
      </div>
    </div>

    {/* Featured + Quote row */}
    <section class="max-w-[1320px] mx-auto px-5 md:px-12 mb-4 md:mb-6">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6">
        {/* Featured large */}
        <div class="md:col-span-7">
          <CategoryCard category={headerCategory} productCount={counts[headerCategory.slug]} size="lg" />
        </div>

        {/* Inline artisan quote */}
        {inlineQuote && (
          <div class="md:col-span-5 bg-surface rounded-2xl p-6 md:p-8 ambient flex flex-col justify-center">
            <EyebrowLabel text="Usta sözü" hairline />
            <div class="mt-4">
              <ArtisanQuote quote={inlineQuote} variant="inline" />
            </div>
          </div>
        )}
      </div>
    </section>

    {/* Remaining categories grid (4 sub + 1 custom) */}
    <section class="max-w-[1320px] mx-auto px-5 md:px-12 mb-10 md:mb-16">
      <h2 class="sr-only">Diğer koleksiyonlar</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
        {subCategories.map((c) => (
          <CategoryCard category={c} productCount={counts[c.slug]} size="md" />
        ))}

        {/* Custom production card */}
        {customCategory && (
          <a
            href={`/kategori/${customCategory.slug}`}
            class="group relative aspect-[4/5] rounded-2xl overflow-hidden bg-secondary-c text-on-secondary-c p-7 md:p-8 flex flex-col justify-between hover:bg-secondary-c/85 transition"
          >
            <div>
              <EyebrowLabel text="Özel proje" hairline tone="light" />
              <h3 class="font-display text-[28px] md:text-[34px] leading-tight mt-3">
                {customCategory.name}<span class="italic"> {customCategory.italicWord}</span>
              </h3>
              <p class="text-[13px] md:text-[14px] opacity-80 mt-3 leading-relaxed">{customCategory.longDescription}</p>
            </div>
            <span class="inline-flex items-center gap-2 text-[11px] uppercase tracking-widest font-bold border-b border-on-secondary-c w-fit pb-1">
              Proje başlat <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
            </span>
          </a>
        )}
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppFAB />
</BaseLayout>
