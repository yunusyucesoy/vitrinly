---
import type { TimelineEvent } from '@lib/schema';

interface Props {
  events: TimelineEvent[];
}

const { events } = Astro.props;
---

<ol class="relative border-l-2 border-outline-v/40 pl-6 md:pl-8 space-y-8 md:space-y-10">
  {events.map((e) => (
    <li class="relative">
      <span class="absolute -left-[31px] md:-left-[37px] top-1 w-3 h-3 rounded-full bg-primary ring-4 ring-surface"></span>
      <div class="text-[10.5px] tracking-[0.25em] uppercase font-bold text-on-surface-v">{e.year}</div>
      <h3 class="font-display text-[22px] md:text-[26px] leading-tight mt-1">{e.title}</h3>
      <p class="text-[14px] text-on-surface-v mt-2 leading-relaxed max-w-md">{e.body}</p>
    </li>
  ))}
</ol>
