---
/**
 * Tam genişlik şerit — kategori detay altı ve ürün detayda kullanılır.
 * Sol: başlık + alt yazı. Sağ: WhatsApp + telefon butonları.
 */
import { getCustomer, buildWhatsAppLink } from '@lib/data';

interface Props {
  title?: string;
  subtitle?: string;
  class?: string;
}

const {
  title = 'Bir ürün hakkında soru mu var?',
  subtitle = 'WhatsApp\'tan satış ekibimize yazın — genelde dakikalar içinde dönüyoruz.',
  class: extraClass = '',
} = Astro.props;

const customer = getCustomer();
const waLink = buildWhatsAppLink(customer.contact.whatsapp);
const telLink = `tel:${customer.contact.phone}`;
---

<section class={`rounded-3xl bg-primary text-on-primary px-6 md:px-12 py-10 md:py-12 ambient flex flex-col md:flex-row md:items-center gap-6 md:gap-10 ${extraClass}`}>
  <div class="flex-1">
    <span class="text-[10px] uppercase tracking-[0.3em] font-bold opacity-70">İletişim</span>
    <h3 class="font-display text-[26px] md:text-[36px] leading-tight mt-2 tracking-tight">{title}</h3>
    <p class="text-[14px] md:text-[15px] opacity-80 mt-3 max-w-xl leading-relaxed">{subtitle}</p>
  </div>

  <div class="flex flex-col sm:flex-row gap-3 md:gap-4 shrink-0">
    <a
      href={waLink}
      class="inline-flex items-center justify-center gap-2 bg-whatsapp text-white py-3 md:py-4 px-6 md:px-7 rounded-full text-[12px] uppercase tracking-[0.22em] font-bold hover:opacity-90 transition"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448L.057 24z"/>
      </svg>
      WhatsApp
    </a>
    <a
      href={telLink}
      class="inline-flex items-center justify-center gap-2 border border-on-primary/40 hover:bg-on-primary/10 py-3 md:py-4 px-6 md:px-7 rounded-full text-[12px] uppercase tracking-[0.22em] font-bold transition"
    >
      <span class="material-symbols-outlined text-[18px]">call</span>
      Telefon
    </a>
  </div>
</section>
